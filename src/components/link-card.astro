---
import CategoryChip from "./CategoryChip.astro";
import TagChip from "./TagChip.astro";

interface Props {
  title: string;
  url?: string;
  categories?: string[];
  tags?: string[];
  static?: boolean;
  cardLink?: string;
  description?: string;
}

const {
  title,
  url = "",
  categories = [],
  tags = [],
  static: isStatic = false,
  cardLink,
  description,
} = Astro.props;
const linkUrl = cardLink || url;
const isExternalLink = !cardLink;
const hasDescription = Boolean(description);
---

<article
  class="link-card not-content"
  data-has-description={hasDescription ? "true" : "false"}
>
  <h3 class="link-title">
    <a
      href={linkUrl}
      target={isExternalLink ? "_blank" : undefined}
      rel={isExternalLink ? "noopener noreferrer" : undefined}>{title}</a
    >
  </h3>

  {description ? <p class="description">{description}</p> : null}

  <div class="chips-container">
    {categories.map((cat) => <CategoryChip category={cat} static={isStatic} />)}
    {tags.map((tag) => <TagChip tag={tag} static={isStatic} />)}
  </div>
</article>

<style>
  .link-card {
    position: relative;
    isolation: isolate;
    overflow: clip;
    display: grid;
    grid-template-rows: 1fr auto;
    gap: 0.75rem;
    margin: 0;
    height: 100%;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1rem;
    background: color-mix(
      in oklab,
      var(--sl-color-bg),
      var(--sl-color-gray-6) 35%
    );
    cursor: pointer;
    transition: background-color 140ms ease;
  }

  .link-card[data-has-description="true"] {
    grid-template-rows: 1fr auto auto;
  }

  .link-card:hover {
    background: color-mix(
      in oklab,
      var(--sl-color-bg),
      var(--sl-color-gray-5) 15%
    );
  }

  .link-card:focus-within {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .link-title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .link-title a {
    position: static;
    color: var(--sl-color-white);
    text-decoration: none;
  }

  .link-title a::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }

  .link-title a:hover,
  .link-title a:focus-visible {
    text-decoration: underline;
  }

  .description {
    margin: 0 0 0.25rem 0;
    color: var(--sl-color-gray-2);
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .meta-info {
    margin: 0.25rem 0 0 0;
    color: var(--sl-color-gray-2);
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .label {
    font-weight: 600;
  }

  .chips-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  /* Progressive enhancement: align title/chip rows across cards via parent subgrid */
  @supports (grid-template-rows: subgrid) {
    .link-card {
      grid-template-rows: subgrid;
      grid-row: span 2;
      height: auto;
      gap: 0.5rem;
    }
  }
</style>

<style is:global>
  /* Keep all secondary interactive controls above stretched primary link. */
  .link-card :where(button, input, select, textarea, summary, [role="button"]) {
    position: relative;
    z-index: 3;
  }
</style>
