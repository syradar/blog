---
import CategoryIcon from "./CategoryIcon.astro";
import {
  categoryColorTokens,
  isLinkCategory,
  type LinkCategory,
} from "../lib/linkCategories";

interface Props {
  category: LinkCategory;
  pressed?: boolean;
}

const { category, pressed = false } = Astro.props;
const safeCategory: LinkCategory = isLinkCategory(category)
  ? category
  : "Other";
const isOther = safeCategory === "Other";
---

<button
  type="button"
  class:list={{ "category-button": true, "is-other": isOther }}
  data-category-button={safeCategory}
  aria-pressed={pressed ? "true" : "false"}
  style={{ "--category-color": categoryColorTokens[safeCategory] }}
>
  <CategoryIcon category={safeCategory} />
  <span class="label">{safeCategory}</span>
</button>

<style>
  .category-button {
    width: 100%;
    height: 100%;
    min-height: 0;
    min-width: 0;
    border-radius: 0.55rem;
    border: 1px solid
      color-mix(in oklab, var(--category-color), var(--sl-color-gray-5) 70%);
    background: color-mix(
      in oklab,
      var(--sl-color-bg),
      var(--category-color) 4%
    );
    color: var(--sl-color-text);
    padding: 0.45rem 0.7rem;
    margin: 0;
    display: grid;
    justify-items: center;
    align-content: center;
    gap: 0.3rem;
    cursor: pointer;
    transition:
      background-color 140ms ease,
      border-color 140ms ease;
  }

  .category-button:hover {
    background: color-mix(
      in oklab,
      var(--sl-color-bg),
      var(--category-color) 8%
    );
  }

  .category-button[aria-pressed="true"] {
    background: color-mix(
      in oklab,
      var(--category-color),
      var(--sl-color-bg) 75%
    );
    border-color: color-mix(
      in oklab,
      var(--category-color),
      var(--sl-color-gray-5) 48%
    );
  }

  .category-button.is-other {
    border-color: color-mix(
      in oklab,
      var(--sl-color-gray),
      var(--sl-color-gray-4) 35%
    );
  }

  .category-button :global(svg) {
    width: 1.2rem;
    height: 1.2rem;
  }

  .label {
    font-size: 0.77rem;
    line-height: 1;
    text-align: center;
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }
</style>
