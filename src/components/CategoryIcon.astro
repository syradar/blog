---
import { Icon } from "astro-icon/components";
import {
  categoryIcons,
  isLinkCategory,
  type LinkCategory,
} from "../lib/linkCategories";

interface Props {
  category: string;
}

const { category } = Astro.props;
const safeCategory: LinkCategory = isLinkCategory(category)
  ? category
  : "Other";
const iconName = categoryIcons[safeCategory];
---

<span class="category-icon" title={safeCategory}>
  <Icon name={iconName} aria-hidden="true" />
</span>

<style>
  .category-icon {
    display: inline-grid;
    place-items: center;
  }

  .category-icon :global(svg) {
    width: 1rem;
    height: 1rem;
  }
</style>
