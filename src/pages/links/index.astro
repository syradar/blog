---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";
import LinksExplorer from "../../components/LinksExplorer.vue";
import {
  getFacetOptions,
  toLinksExplorerRecords,
} from "../../lib/links-explorer";
import { buildLinksIndexSnapshot } from "../../lib/links-search";
import { buildHeadForRoute } from "../../lib/og";

const linkWeeks = await getCollection("linkWeeks");
const records = toLinksExplorerRecords(linkWeeks);
const facets = getFacetOptions(records);
const indexSnapshot = await buildLinksIndexSnapshot(records);
const head = Astro.site ? await buildHeadForRoute("/links", Astro.site) : [];
---

<StarlightPage
  frontmatter={{
    title: "Link Collection",
    tableOfContents: false,
    head,
  }}
>
  <p class="page-intro">
    Explore every link across issues, then narrow by search text, category, tag,
    or Link Week.
  </p>

  <p class="archive-link">
    Prefer browsing by issue? Visit <a href="/blog/links/weeks"
      >Weekly Links Archive</a
    >.
  </p>

  <LinksExplorer {records} {facets} {indexSnapshot} client:load />
</StarlightPage>

<style>
  .page-intro {
    margin: 0 0 0.25rem;
  }

  .archive-link {
    margin: 0 0 1rem;
  }
</style>
